generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum OrderStatus {
  PENDING
  PACKING
  FINISHED
  CANCELLED
}

enum OrderChannel {
  SHOPEE
  TIKTOK
  LINE
}

enum OrderCategory {
  ONE_ITEM
  TWO_ITEMS
  THREE_PLUS
  MIXED
}

enum SyncStatus {
  SYNCED
  PENDING_SYNC
  FAILED
}

// Physical Inventory Item (The raw material / central stock)
model Product {
  id              String            @id @default(uuid())
  code            String            @unique // e.g., 'POPPING_BARLEY'
  name            String
  baseStock       Int               @default(0) // Physical stock count
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  
  variants        ProductVariant[]
  inventoryLogs   InventoryLog[]
}

// Sellable SKU (e.g. 1 pack, 3 pack)
model ProductVariant {
  id              String            @id @default(uuid())
  productId       String
  sku             String            @unique // e.g., 'POPPING_BARLEY_1', 'POPPING_BARLEY_3'
  name            String
  packSize        Int               @default(1) // Number of base products this variant consumes (1 or 3)
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  product         Product           @relation(fields: [productId], references: [id], onDelete: Cascade)
  channelProducts ChannelProduct[]
  orderItems      OrderItem[]
}

model ChannelProduct {
  id               String         @id @default(uuid())
  productVariantId String
  channel          String         // e.g., 'SHOPEE', 'TIKTOK', 'LINE'
  channelSku       String
  channelProductId String?        // Platform's internal product ID if applicable
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt

  productVariant   ProductVariant @relation(fields: [productVariantId], references: [id], onDelete: Cascade)

  @@unique([channel, channelSku])
}

model Order {
  id              String        @id @default(uuid())
  channel         OrderChannel
  channelOrderId  String        @unique
  status          OrderStatus   @default(PENDING)
  category        OrderCategory @default(ONE_ITEM)
  syncStatus      SyncStatus    @default(SYNCED)
  shipByDate      DateTime      @default(now())
  packedBy        String?       // Employee name
  packedAt        DateTime?
  finishedAt      DateTime?
  totalQuantity   Int           @default(0)
  total           Float         @default(0)
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  orderItems      OrderItem[]

  @@index([status])
  @@index([channel])
  @@index([finishedAt])
  @@index([createdAt])
}

model OrderItem {
  id               String         @id @default(uuid())
  orderId          String
  productVariantId String
  quantity         Int
  price            Float          @default(0)
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt

  order            Order          @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productVariant   ProductVariant @relation(fields: [productVariantId], references: [id], onDelete: Restrict)
}

model InventoryLog {
  id              String   @id @default(uuid())
  productId       String
  change          Int      // e.g., -1 for deduction, +1 for addition
  reason          String   // e.g., 'ORDER_PLACED', 'MANUAL_ADJUSTMENT'
  referenceId     String?  // Could be Order ID or adjustment reference
  createdAt       DateTime @default(now())

  product         Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
}

// Stores OAuth credentials for different shops
model ShopCredentials {
  id             String       @id @default(uuid())
  channel        OrderChannel
  shopId         String       @unique
  accessToken    String
  refreshToken   String
  expiresAt      DateTime     // When access_token expires
  refreshExpiresAt DateTime   // When refresh_token expires
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
}